rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ⚠️ WARNING: Test Mode
    // The OASI Portal currently uses a custom plaintext authentication system
    // which does not establish a true Firebase Auth session (`request.auth` is null).
    // Therefore, strict backend rules cannot be mathematically enforced without breaking the app.
    // The Hierarchy Lock relies entirely on the React UI-level locks until 
    // migration to Firebase Authentication is complete.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
